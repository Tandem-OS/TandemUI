{
  "$schema": "https://tandem.design/schemas/tokens/primitives/gradients.json",
  "$description": "Gradient primitives - Formula-based gradients referencing color primitives. No raw values.",
  "$version": "2.0.0",
  "$hierarchy": "primitives/colors.json → THIS FILE → semantic/gradients.json → themes/[light|dark].json → components",
  "$rule": "ALL gradient colors MUST reference {primitives.colors.*}",

  "$types": {
    "linear": "Linear gradients with direction",
    "radial": "Radial gradients from center",
    "conic": "Conic gradients (color wheel)",
    "mesh": "Multi-point gradient meshes"
  },

  "linear": {
    "primary": {
      "type": "linear-gradient",
      "angle": 135,
      "stops": [
        {
          "color": "{primitives.colors.indigo.500}",
          "position": 0
        },
        {
          "color": "{primitives.colors.indigo.600}",
          "position": 100
        }
      ],
      "css": "linear-gradient(135deg, {stop1} 0%, {stop2} 100%)"
    },

    "primaryToSecondary": {
      "type": "linear-gradient",
      "angle": 135,
      "stops": [
        {
          "color": "{primitives.colors.indigo.500}",
          "position": 0
        },
        {
          "color": "{primitives.colors.orange.500}",
          "position": 100
        }
      ],
      "css": "linear-gradient(135deg, {stop1} 0%, {stop2} 100%)"
    },

    "primaryToTertiary": {
      "type": "linear-gradient",
      "angle": 135,
      "stops": [
        {
          "color": "{primitives.colors.indigo.500}",
          "position": 0
        },
        {
          "color": "{primitives.colors.emerald.500}",
          "position": 100
        }
      ],
      "css": "linear-gradient(135deg, {stop1} 0%, {stop2} 100%)"
    },

    "secondaryToTertiary": {
      "type": "linear-gradient",
      "angle": 135,
      "stops": [
        {
          "color": "{primitives.colors.orange.400}",
          "position": 0
        },
        {
          "color": "{primitives.colors.emerald.500}",
          "position": 100
        }
      ],
      "css": "linear-gradient(135deg, {stop1} 0%, {stop2} 100%)"
    },

    "rainbow": {
      "type": "linear-gradient",
      "angle": 90,
      "stops": [
        {
          "color": "{primitives.colors.red.500}",
          "position": 0
        },
        {
          "color": "{primitives.colors.orange.400}",
          "position": 16.6
        },
        {
          "color": "{primitives.colors.yellow.400}",
          "position": 33.3
        },
        {
          "color": "{primitives.colors.green.500}",
          "position": 50
        },
        {
          "color": "{primitives.colors.blue.500}",
          "position": 66.6
        },
        {
          "color": "{primitives.colors.purple.500}",
          "position": 83.3
        },
        {
          "color": "{primitives.colors.pink.500}",
          "position": 100
        }
      ],
      "css": "linear-gradient(90deg, {colors...})"
    },

    "neutral": {
      "type": "linear-gradient",
      "angle": 180,
      "stops": [
        {
          "color": "{primitives.colors.neutral.100}",
          "position": 0
        },
        {
          "color": "{primitives.colors.neutral.200}",
          "position": 100
        }
      ],
      "css": "linear-gradient(180deg, {stop1} 0%, {stop2} 100%)"
    },

    "shine": {
      "type": "linear-gradient",
      "angle": 45,
      "stops": [
        {
          "color": "{primitives.colors.neutral.0}",
          "opacity": 0,
          "position": 0
        },
        {
          "color": "{primitives.colors.neutral.0}",
          "opacity": 0.4,
          "position": 50
        },
        {
          "color": "{primitives.colors.neutral.0}",
          "opacity": 0,
          "position": 100
        }
      ],
      "css": "linear-gradient(45deg, transparent 0%, rgba(255,255,255,0.4) 50%, transparent 100%)"
    },

    "glass": {
      "type": "linear-gradient",
      "angle": 180,
      "stops": [
        {
          "color": "{primitives.colors.neutral.0}",
          "opacity": 0.8,
          "position": 0
        },
        {
          "color": "{primitives.colors.neutral.0}",
          "opacity": 0.4,
          "position": 100
        }
      ],
      "css": "linear-gradient(180deg, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0.4) 100%)"
    }
  },

  "radial": {
    "primary": {
      "type": "radial-gradient",
      "shape": "circle",
      "position": "center",
      "stops": [
        {
          "color": "{primitives.colors.indigo.400}",
          "position": 0
        },
        {
          "color": "{primitives.colors.indigo.600}",
          "position": 100
        }
      ],
      "css": "radial-gradient(circle at center, {stop1} 0%, {stop2} 100%)"
    },

    "spotlight": {
      "type": "radial-gradient",
      "shape": "circle",
      "position": "center",
      "stops": [
        {
          "color": "{primitives.colors.neutral.0}",
          "opacity": 0.8,
          "position": 0
        },
        {
          "color": "{primitives.colors.neutral.0}",
          "opacity": 0,
          "position": 70
        }
      ],
      "css": "radial-gradient(circle at center, rgba(255,255,255,0.8) 0%, transparent 70%)"
    },

    "glow": {
      "type": "radial-gradient",
      "shape": "circle",
      "position": "center",
      "stops": [
        {
          "color": "{primitives.colors.indigo.500}",
          "opacity": 0.3,
          "position": 0
        },
        {
          "color": "{primitives.colors.indigo.500}",
          "opacity": 0,
          "position": 100
        }
      ],
      "css": "radial-gradient(circle at center, rgba(91,102,245,0.3) 0%, transparent 100%)"
    }
  },

  "conic": {
    "rainbow": {
      "type": "conic-gradient",
      "startAngle": 0,
      "position": "center",
      "stops": [
        {
          "color": "{primitives.colors.red.500}",
          "position": 0
        },
        {
          "color": "{primitives.colors.orange.500}",
          "position": 60
        },
        {
          "color": "{primitives.colors.yellow.500}",
          "position": 120
        },
        {
          "color": "{primitives.colors.green.500}",
          "position": 180
        },
        {
          "color": "{primitives.colors.blue.500}",
          "position": 240
        },
        {
          "color": "{primitives.colors.purple.500}",
          "position": 300
        },
        {
          "color": "{primitives.colors.red.500}",
          "position": 360
        }
      ],
      "css": "conic-gradient(from 0deg at center, {colors...})"
    }
  },

  "mesh": {
    "hero": {
      "type": "mesh-gradient",
      "description": "Multi-point gradient for hero backgrounds",
      "colors": [
        {
          "color": "{primitives.colors.indigo.500}",
          "position": "top-left",
          "strength": 0.8
        },
        {
          "color": "{primitives.colors.orange.400}",
          "position": "top-right",
          "strength": 0.6
        },
        {
          "color": "{primitives.colors.emerald.500}",
          "position": "bottom-left",
          "strength": 0.4
        },
        {
          "color": "{primitives.colors.purple.500}",
          "position": "bottom-right",
          "strength": 0.5
        }
      ],
      "fallback": "linear-gradient(135deg, {primitives.colors.indigo.500} 0%, {primitives.colors.purple.600} 100%)"
    },

    "subtle": {
      "type": "mesh-gradient",
      "description": "Subtle multi-point gradient for backgrounds",
      "colors": [
        {
          "color": "{primitives.colors.indigo.50}",
          "position": "top-left",
          "strength": 1
        },
        {
          "color": "{primitives.colors.orange.25}",
          "position": "top-right",
          "strength": 0.8
        },
        {
          "color": "{primitives.colors.emerald.25}",
          "position": "bottom-left",
          "strength": 0.6
        },
        {
          "color": "{primitives.colors.purple.25}",
          "position": "bottom-right",
          "strength": 0.7
        }
      ],
      "fallback": "linear-gradient(135deg, {primitives.colors.indigo.50} 0%, {primitives.colors.purple.50} 100%)"
    }
  },

  "$overlays": {
    "description": "Gradient overlays for images and backgrounds",
    
    "scrim": {
      "type": "linear-gradient",
      "angle": 180,
      "stops": [
        {
          "color": "{primitives.colors.neutral.900}",
          "opacity": 0,
          "position": 0
        },
        {
          "color": "{primitives.colors.neutral.900}",
          "opacity": 0.6,
          "position": 100
        }
      ],
      "usage": ["Image overlays to ensure text readability"],
      "css": "linear-gradient(180deg, transparent 0%, rgba(26,29,46,0.6) 100%)"
    },

    "vignette": {
      "type": "radial-gradient",
      "shape": "ellipse",
      "position": "center",
      "stops": [
        {
          "color": "{primitives.colors.neutral.900}",
          "opacity": 0,
          "position": 0
        },
        {
          "color": "{primitives.colors.neutral.900}",
          "opacity": 0.7,
          "position": 100
        }
      ],
      "usage": ["Edge darkening effect"],
      "css": "radial-gradient(ellipse at center, transparent 0%, rgba(26,29,46,0.7) 100%)"
    }
  }
}
