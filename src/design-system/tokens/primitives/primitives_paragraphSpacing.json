{
  "$schema": "https://tandem.design/schemas/tokens/primitives/paragraphSpacing.json",
  "$description": "Paragraph spacing primitives - Raw em values for space between paragraphs. Mobile needs slightly more breathing room.",
  "$version": "2.0.0",
  "$hierarchy": "THIS FILE (raw em) → semantic (context) → components/*.json",

  "desktop": {
    "none": {
      "value": "0",
      "usage": "No paragraph spacing"
    },
    "tight": {
      "value": "0.75em",
      "usage": "Minimal space between paragraphs"
    },
    "comfortable": {
      "value": "1em",
      "default": true,
      "usage": "Standard paragraph spacing (1× font size)"
    },
    "relaxed": {
      "value": "1.25em",
      "usage": "Comfortable reading spacing"
    },
    "spacious": {
      "value": "1.5em",
      "usage": "Generous paragraph spacing"
    },
    "dramatic": {
      "value": "2em",
      "usage": "Very loose, editorial style (2× font size)"
    }
  },

  "mobile": {
    "none": {
      "value": "0",
      "usage": "No paragraph spacing (mobile)"
    },
    "tight": {
      "value": "0.875em",
      "usage": "Minimal space (mobile) - slightly more than desktop"
    },
    "comfortable": {
      "value": "1.125em",
      "default": true,
      "usage": "Standard (mobile) - 12.5% more than desktop"
    },
    "relaxed": {
      "value": "1.375em",
      "usage": "Comfortable (mobile)"
    },
    "spacious": {
      "value": "1.625em",
      "usage": "Generous (mobile)"
    },
    "dramatic": {
      "value": "2.25em",
      "usage": "Very loose (mobile)"
    }
  },

  "$mobileOptimization": {
    "principle": "Mobile needs ~10-15% more paragraph spacing for thumb-scroll clarity",
    "recommendation": "+0.125em to +0.25em over desktop values",
    "reasoning": "Prevents visual crowding on small screens, improves scannability during scroll"
  },

  "$accessibilityRequirement": {
    "minimum": "At least 2× font size (WCAG 1.4.12)",
    "standard": "1-1.5× font size for comfortable reading",
    "recommendation": "Use 'comfortable' (1em desktop, 1.125em mobile) as baseline"
  },

  "$cssImplementation": {
    "property": "margin-bottom on <p> tags",
    "example": "p { margin-bottom: 1em; }",
    "responsive": "p { margin-bottom: 1.125em; } @media (min-width: 1024px) { p { margin-bottom: 1em; } }"
  },

  "$tailwindMapping": {
    "desktop": {
      "none": "mb-0",
      "tight": "mb-3",
      "comfortable": "mb-4",
      "relaxed": "mb-5",
      "spacious": "mb-6",
      "dramatic": "mb-8"
    },
    "mobile": {
      "comfortable": "mb-[1.125em]",
      "relaxed": "mb-[1.375em]",
      "spacious": "mb-[1.625em]"
    },
    "responsive": {
      "comfortable": "mb-[1.125em] lg:mb-4",
      "relaxed": "mb-[1.375em] lg:mb-5",
      "spacious": "mb-[1.625em] lg:mb-6"
    }
  },

  "$usageByContentType": {
    "articles": {
      "desktop": "comfortable to relaxed (1-1.25em)",
      "mobile": "comfortable to relaxed (1.125-1.375em)"
    },
    "blogs": {
      "desktop": "relaxed to spacious (1.25-1.5em)",
      "mobile": "relaxed to spacious (1.375-1.625em)"
    },
    "documentation": {
      "desktop": "tight to comfortable (0.75-1em)",
      "mobile": "comfortable (1.125em)"
    },
    "marketing": {
      "desktop": "spacious to dramatic (1.5-2em)",
      "mobile": "spacious to dramatic (1.625-2.25em)"
    }
  },

  "$personalityMapping": {
    "technical": ["tight", "comfortable"],
    "editorial": ["comfortable", "relaxed"],
    "friendly": ["relaxed", "spacious"],
    "luxury": ["spacious", "dramatic"]
  }
}
