{
  "$schema": "https://tandem.design/schemas/tokens/primitives/motion.json",
  "$description": "Motion primitives - Duration and Easing values.",
  "$version": "1.0.0",
  
  "duration": {
    "0": "0ms",
    "50": "50ms",
