{
  "$schema": "https://tandem.design/schemas/tokens/primitives/fontSize.json",
  "$description": "Font size primitives - Raw pixel/rem values with separate mobile and desktop scales for optimal readability.",
  "$version": "2.0.0",
  "$hierarchy": "THIS FILE (raw px/rem) → semantic/typography.json → components/*.json",
  "$baseSize": "16px",
  "$scalingRatio": "1.333 (perfect fourth)",

  "desktop": {
    "xs": {
      "value": "12px",
      "rem": "0.75rem",
      "usage": "Fine print, captions, metadata"
    },
    "sm": {
      "value": "14px",
      "rem": "0.875rem",
      "usage": "Small text, labels, secondary content"
    },
    "base": {
      "value": "16px",
      "rem": "1rem",
      "default": true,
      "usage": "Body text, primary content"
    },
    "lg": {
      "value": "18px",
      "rem": "1.125rem",
      "usage": "Large body, lead paragraphs"
    },
    "xl": {
      "value": "20px",
      "rem": "1.25rem",
      "usage": "Featured text, small headings"
    },
    "2xl": {
      "value": "24px",
      "rem": "1.5rem",
      "usage": "H4, medium headings"
    },
    "3xl": {
      "value": "30px",
      "rem": "1.875rem",
      "usage": "H3, section headings"
    },
    "4xl": {
      "value": "36px",
      "rem": "2.25rem",
      "usage": "H2, subsection headings"
    },
    "5xl": {
      "value": "48px",
      "rem": "3rem",
      "usage": "H1, page headings"
    },
    "6xl": {
      "value": "60px",
      "rem": "3.75rem",
      "usage": "Hero headings, display text"
    },
    "7xl": {
      "value": "72px",
      "rem": "4.5rem",
      "usage": "Large hero, marketing pages"
    },
    "8xl": {
      "value": "96px",
      "rem": "6rem",
      "usage": "Extra large display"
    },
    "9xl": {
      "value": "128px",
      "rem": "8rem",
      "usage": "Massive display (rare)"
    }
  },

  "mobile": {
    "xs": {
      "value": "11px",
      "rem": "0.6875rem",
      "usage": "Fine print, captions (mobile)"
    },
    "sm": {
      "value": "13px",
      "rem": "0.8125rem",
      "usage": "Small text, labels (mobile)"
    },
    "base": {
      "value": "16px",
      "rem": "1rem",
      "default": true,
      "usage": "Body text (mobile) - never smaller than 16px for accessibility"
    },
    "lg": {
      "value": "17px",
      "rem": "1.0625rem",
      "usage": "Large body (mobile)"
    },
    "xl": {
      "value": "19px",
      "rem": "1.1875rem",
      "usage": "Featured text (mobile)"
    },
    "2xl": {
      "value": "22px",
      "rem": "1.375rem",
      "usage": "H4 (mobile)"
    },
    "3xl": {
      "value": "26px",
      "rem": "1.625rem",
      "usage": "H3 (mobile)"
    },
    "4xl": {
      "value": "30px",
      "rem": "1.875rem",
      "usage": "H2 (mobile)"
    },
    "5xl": {
      "value": "36px",
      "rem": "2.25rem",
      "usage": "H1 (mobile)"
    },
    "6xl": {
      "value": "42px",
      "rem": "2.625rem",
      "usage": "Hero (mobile)"
    },
    "7xl": {
      "value": "48px",
      "rem": "3rem",
      "usage": "Large hero (mobile)"
    },
    "8xl": {
      "value": "56px",
      "rem": "3.5rem",
      "usage": "Extra large (mobile)"
    }
  },

  "$responsiveMapping": {
    "pattern": "mobile-first with desktop overrides",
    "example": "text-base lg:text-lg (16px mobile, 18px desktop)",
    "breakpoint": "lg (1024px)"
  },

  "$accessibilityMinimums": {
    "bodyText": "16px minimum - critical for readability and iOS Safari zoom prevention",
    "smallText": "12px absolute minimum - use sparingly",
    "recommendation": "Never use less than 16px for primary body content on mobile"
  },

  "$tailwindMapping": {
    "desktop": {
      "xs": "text-xs",
      "sm": "text-sm",
      "base": "text-base",
      "lg": "text-lg",
      "xl": "text-xl",
      "2xl": "text-2xl",
      "3xl": "text-3xl",
      "4xl": "text-4xl",
      "5xl": "text-5xl",
      "6xl": "text-6xl",
      "7xl": "text-7xl",
      "8xl": "text-8xl",
      "9xl": "text-9xl"
    },
    "responsive": {
      "xs": "text-xs lg:text-xs",
      "sm": "text-sm lg:text-sm",
      "base": "text-base lg:text-base",
      "lg": "text-base lg:text-lg",
      "xl": "text-lg lg:text-xl",
      "2xl": "text-xl lg:text-2xl",
      "3xl": "text-2xl lg:text-3xl",
      "4xl": "text-2xl lg:text-4xl",
      "5xl": "text-3xl lg:text-5xl",
      "6xl": "text-4xl lg:text-6xl",
      "7xl": "text-5xl lg:text-7xl",
      "8xl": "text-6xl lg:text-8xl"
    }
  },

  "$fluidTypography": {
    "description": "CSS clamp() for smooth scaling between mobile and desktop",
    "examples": {
      "h1": "clamp(2.25rem, 1.5rem + 2vw, 3.75rem)",
      "h2": "clamp(1.875rem, 1.25rem + 1.5vw, 2.25rem)",
      "body": "clamp(1rem, 0.95rem + 0.25vw, 1.125rem)"
    }
  }
}
