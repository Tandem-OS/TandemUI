{
  "$schema": "https://tandem.design/schemas/tokens/primitives/borderRadius.json",
  "$description": "Border radius primitives - Expanded granular scale for nuanced personality control. Raw pixel values only.",
  "$version": "2.0.0",
  "$hierarchy": "THIS FILE (raw px) → semantic (context) → components/*.json",
  "$rationale": "Expanded from 8 to 16 values to support subtle personality variations and micro-adjustments",

  "none": {
    "value": "0px",
    "usage": "Sharp edges, technical interfaces, brutalist design"
  },
  "2xs": {
    "value": "2px",
    "rem": "0.125rem",
    "usage": "Barely perceptible rounding, technical-minimal hybrid"
  },
  "xs": {
    "value": "3px",
    "rem": "0.1875rem",
    "usage": "Micro rounding, subtle softening of hard edges"
  },
  "sm": {
    "value": "4px",
    "rem": "0.25rem",
    "usage": "Minimal rounding, editorial precision"
  },
  "sm-md": {
    "value": "6px",
    "rem": "0.375rem",
    "usage": "Between minimal and balanced, refined modern"
  },
  "md": {
    "value": "8px",
    "rem": "0.5rem",
    "usage": "Balanced rounding, modern standard"
  },
  "md-lg": {
    "value": "10px",
    "rem": "0.625rem",
    "usage": "Between balanced and generous, approachable-professional"
  },
  "lg": {
    "value": "12px",
    "rem": "0.75rem",
    "usage": "Generous rounding, friendly professional"
  },
  "lg-xl": {
    "value": "14px",
    "rem": "0.875rem",
    "usage": "Between generous and warm, consumer-friendly"
  },
  "xl": {
    "value": "16px",
    "rem": "1rem",
    "usage": "Warm rounding, consumer-centric"
  },
  "xl-2xl": {
    "value": "20px",
    "rem": "1.25rem",
    "usage": "Between warm and soft-playful, lifestyle brands"
  },
  "2xl": {
    "value": "24px",
    "rem": "1.5rem",
    "usage": "Soft playful rounding, wellness/lifestyle"
  },
  "2xl-3xl": {
    "value": "28px",
    "rem": "1.75rem",
    "usage": "Between soft and exaggerated, high-energy brands"
  },
  "3xl": {
    "value": "32px",
    "rem": "2rem",
    "usage": "Exaggerated rounding, playful/kids apps"
  },
  "4xl": {
    "value": "40px",
    "rem": "2.5rem",
    "usage": "Maximum rounding for large surfaces, bubbly aesthetic"
  },
  "5xl": {
    "value": "48px",
    "rem": "3rem",
    "usage": "Extreme rounding, hero elements only"
  },
  "full": {
    "value": "9999px",
    "usage": "Pills, circles, maximum rounded elements"
  }
}