{
  "$schema": "https://tandem.design/schemas/tokens/primitives/letterSpacing.json",
  "$description": "Letter spacing primitives - Raw em values. Mobile typically needs slightly looser tracking for readability.",
  "$version": "2.0.0",
  "$hierarchy": "THIS FILE (raw em) → semantic/typography.json → components/*.json",

  "desktop": {
    "tightest": {
      "value": "-0.05em",
      "usage": "Extreme tight tracking for large display text"
    },
    "tighter": {
      "value": "-0.02em",
      "usage": "Tight tracking for headings"
    },
    "tight": {
      "value": "-0.01em",
      "usage": "Slightly tight for subheadings"
    },
    "normal": {
      "value": "0",
      "default": true,
      "usage": "Default spacing for body text"
    },
    "wide": {
      "value": "0.01em",
      "usage": "Slightly loose for labels"
    },
    "wider": {
      "value": "0.02em",
      "usage": "Loose for small caps, overlines"
    },
    "widest": {
      "value": "0.05em",
      "usage": "Very loose for emphasis"
    },
    "ultra": {
      "value": "0.1em",
      "usage": "Ultra loose for special effects"
    }
  },

  "mobile": {
    "tightest": {
      "value": "-0.03em",
      "usage": "Tight tracking on mobile (less extreme than desktop)"
    },
    "tighter": {
      "value": "-0.015em",
      "usage": "Slightly tight for headings (mobile)"
    },
    "tight": {
      "value": "-0.005em",
      "usage": "Minimal tightening (mobile)"
    },
    "normal": {
      "value": "0",
      "default": true,
      "usage": "Default spacing (mobile)"
    },
    "wide": {
      "value": "0.015em",
      "usage": "Slightly loose - better for small screens"
    },
    "wider": {
      "value": "0.025em",
      "usage": "Loose for labels and small text"
    },
    "widest": {
      "value": "0.06em",
      "usage": "Very loose for uppercase text"
    },
    "ultra": {
      "value": "0.12em",
      "usage": "Ultra loose (mobile)"
    }
  },

  "$mobileOptimization": {
    "principle": "Mobile screens benefit from slightly looser tracking for improved readability",
    "recommendation": "Add +0.005em to +0.01em to desktop values for mobile body text",
    "reasoning": "Smaller screen sizes and varying pixel densities make looser tracking more legible"
  },

  "$tailwindMapping": {
    "desktop": {
      "tightest": "tracking-tightest",
      "tighter": "tracking-tighter",
      "tight": "tracking-tight",
      "normal": "tracking-normal",
      "wide": "tracking-wide",
      "wider": "tracking-wider",
      "widest": "tracking-widest"
    },
    "customValues": {
      "ultra": "tracking-[0.1em]",
      "mobileWide": "tracking-[0.015em]"
    }
  },

  "$accessibilityGuidance": {
    "minimum": "At least 0.12× font size (WCAG 1.4.12)",
    "bodyText": "Use 'normal' (0) or slightly positive values",
    "headings": "Negative values acceptable but test for readability",
    "uppercase": "Always use positive tracking (0.02em minimum)"
  },

  "$personalityMapping": {
    "technical": ["tightest", "tighter", "tight"],
    "editorial": ["tight", "normal"],
    "friendly": ["normal", "wide"],
    "luxury": ["wide", "wider", "widest"]
  }
}
