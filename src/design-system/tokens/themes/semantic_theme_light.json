{
  "$schema": "https://tandem.design/schemas/tokens/themes/light.json",
  "$description": "Light theme - Complete semantic token system with all component colors, states, and usage guidelines",
  "$version": "2.0.0",
  "$references": ["primitives/colors.json", "semantic/colors.json"],
  "$name": "Tandem Light (Emerald Fresh)",
  "$mode": "light",
  
  "$brandPersonality": {
    "primary": "Fresh, modern, approachable",
    "secondary": "Professional yet friendly",
    "voice": "Clear, confident, helpful",
    "tone": "Optimistic and enabling",
    "values": ["Innovation", "Growth", "Trustworthiness", "Clarity", "Accessibility"],
    "archetype": "The Enabler - Empowering users to create and innovate",
    "emotionalGoal": "Users feel confident, capable, and inspired"
  },

  "$toneAndVoice": {
    "communicationPrinciples": {
      "clarity": "Direct and unambiguous - users always know what to expect",
      "warmth": "Friendly without being casual - professional but approachable",
      "confidence": "Assured and reliable - never uncertain or apologetic",
      "empowerment": "Focus on what users can do, not what they can't",
      "brevity": "Concise and scannable - respect user's time"
    },
    "vocabulary": {
      "preferred": ["Create", "Build", "Design", "Explore", "Discover", "Enable", "Empower", "Transform", "Innovate"],
      "avoid": ["Submit", "Cancel", "Error", "Failed", "Invalid", "Wrong"],
      "replacements": {
        "Error": "Needs attention",
        "Failed": "Didn't work",
        "Invalid": "Doesn't match",
        "Submit": "Continue",
        "Cancel": "Go back"
      }
    },
    "microcopy": {
      "buttons": {
        "primary": "Action-oriented verbs (Save, Create, Continue, Get started)",
        "secondary": "Lower commitment (Learn more, Maybe later, Review)",
        "destructive": "Clear consequences (Delete forever, Remove permanently)"
      },
      "errors": {
        "tone": "Helpful, not blaming",
        "structure": "What happened + Why + How to fix",
        "example": "Email format doesn't match. Try: name@company.com"
      },
      "success": {
        "tone": "Celebratory but brief",
        "example": "Done! Your project is live."
      },
      "empty": {
        "tone": "Encouraging, not deflating",
        "structure": "Current state + What you can do",
        "example": "No projects yet. Create your first one to get started."
      }
    }
  },

  "$accessibility": {
    "$wcagLevel": "AA",
    "$standard": "WCAG 2.1",
    "$target": "AAA where feasible",
    "$contrastRatios": {
      "emerald.500/neutral.0": "4.8:1 (AA Large Text, AA UI)",
      "emerald.600/neutral.0": "5.9:1 (AA All Text)",
      "neutral.900/neutral.0": "15.2:1 (AAA)",
      "neutral.700/neutral.0": "9.1:1 (AAA)",
      "neutral.600/neutral.0": "7.2:1 (AAA)",
      "green.600/neutral.0": "5.2:1 (AA)",
      "red.600/neutral.0": "5.1:1 (AA)"
    },
    "$minimums": {
      "normalText": "4.5:1 (14px regular)",
      "largeText": "3:1 (18px regular or 14px bold)",
      "uiComponents": "3:1 (borders, icons, focus indicators)",
      "graphicalObjects": "3:1 (charts, infographics)"
    },
    "$colorBlindness": {
      "tested": ["deuteranopia", "protanopia", "tritanopia"],
      "strategy": "Never rely on color alone - always pair with text, icons, or patterns",
      "statusColors": "All status colors distinguishable by icon + text + color",
      "brandColors": "Emerald/orange pair maintains distinction across all types"
    },
    "$tapTargets": {
      "minimum": "44x44px",
      "recommended": "48x48px",
      "spacing": "8px minimum between targets",
      "applies": "All interactive elements: buttons, links, form controls, icons"
    },
    "$keyboardNavigation": {
      "focusVisible": "All interactive elements must have visible focus indicator",
      "focusOrder": "Logical top-to-bottom, left-to-right order",
      "skipLinks": "Provide skip navigation for repeated content",
      "shortcuts": "Document all keyboard shortcuts, avoid conflicts"
    },
    "$screenReaders": {
      "labels": "All interactive elements must have accessible labels",
      "landmarks": "Use semantic HTML5 landmarks (header, nav, main, aside, footer)",
      "headings": "Proper heading hierarchy (h1-h6) without skipping levels",
      "altText": "Descriptive alt text for images, empty alt for decorative",
      "ariaLabels": "Use ARIA only when semantic HTML insufficient"
    },
    "$motion": {
      "respectPrefersReducedMotion": true,
      "fallback": "Instant state changes for users with motion sensitivity",
      "essential": "Only animate when it aids understanding, not decoration"
    },
    "$forms": {
      "labels": "Visible labels for all inputs, not just placeholders",
      "errors": "Clear error messages with icon + color + text",
      "instructions": "Helper text before user makes mistake, not after",
      "validation": "Inline validation after field loses focus"
    },
    "$notes": "All combinations meet WCAG 2.1 AA standards. Many exceed to AAA."
  },

  "$usageGuidelines": {
    "$whenToUse": {
      "primary": "Main action user should take (1 per screen max)",
      "secondary": "Alternative actions or lower priority tasks",
      "tertiary": "Subtle actions that don't warrant visual weight",
      "accent": "Special promotions, unique features, calls-to-action",
      "destructive": "Permanent deletions, irreversible actions"
    },
    "$hierarchy": {
      "principle": "Visual weight = importance = frequency of use",
      "example": "Primary (Save) > Secondary (Preview) > Tertiary (Cancel)",
      "never": "Never have two primary buttons in same view competing"
    },
    "$consistency": {
      "placement": "Primary action always in same position (bottom-right for forms)",
      "wording": "Use same words for same actions across product",
      "icons": "Same icon always means same thing",
      "colors": "Status colors have consistent meaning (green = success, etc.)"
    },
    "$spacing": {
      "buttonGroups": "16px between buttons in group",
      "sections": "32px between major sections",
      "cards": "24px between cards in grid",
      "inline": "8px for inline elements (badges, chips)"
    },
    "$responsive": {
      "breakpoints": {
        "mobile": "< 640px - Stack buttons vertically, full width",
        "tablet": "640-1024px - Side-by-side where space permits",
        "desktop": "> 1024px - Optimal spacing and density"
      },
      "priority": "Mobile-first design, progressive enhancement"
    }
  },

  "$behavioralTags": {
    "vibe": ["modern", "fresh", "professional", "trustworthy", "innovative"],
    "mood": ["optimistic", "confident", "calm", "focused", "empowering"],
    "tempo": ["efficient", "smooth", "responsive", "immediate"],
    "conversion": ["clear-cta", "low-friction", "trust-building", "value-focused"],
    "personality": ["helpful", "clear", "non-judgmental", "encouraging"],
    "userEmotion": ["confident", "capable", "inspired", "in-control"]
  },

  "$aiGenerationHints": {
    "promptKeywords": ["modern design system", "emerald green brand", "professional SaaS", "accessible interface", "clear hierarchy"],
    "styleDescriptors": ["clean", "minimal", "spacious", "organized", "trustworthy"],
    "colorMood": "Fresh and modern with emerald/teal primary suggesting growth and innovation, balanced with warm coral accents",
    "typicalUseCase": "SaaS products, productivity tools, design platforms, developer tools, creative software",
    "targetAudience": "Professionals, creators, designers, developers - tech-savvy users who value clarity and efficiency",
    "brandAdaptation": {
      "conservative": "Reduce emerald saturation by 20%, increase neutral usage",
      "playful": "Increase accent color usage, add more tint backgrounds",
      "luxury": "Increase spacing, reduce color variety, focus on emerald + neutrals",
      "energetic": "More accent color, brighter tints, increase contrast"
    },
    "contentConstraints": {
      "buttonText": "2-4 words maximum, action verbs preferred",
      "headings": "5-8 words for h1, 3-5 words for h2-h6",
      "body": "12-16 words per sentence average, 3-4 sentences per paragraph",
      "microcopy": "Error messages 8-12 words, success messages 3-5 words"
    }
  },

  "$designPrinciples": {
    "clarity": "Every element has a clear purpose and meaning",
    "consistency": "Patterns repeat predictably across the entire system",
    "efficiency": "Users accomplish tasks with minimum friction",
    "accessibility": "Inclusive design for all abilities and contexts",
    "scalability": "System grows without breaking or becoming chaotic",
    "delight": "Small moments of joy without compromising usability"
  },

  "$performanceGuidelines": {
    "criticalCSS": "Inline above-the-fold colors to prevent flash of unstyled content",
    "colorFormat": "Use hex for static colors, rgba only for opacity/overlays",
    "cssVariables": "Leverage CSS custom properties for theme switching",
    "bundleSize": "Color tokens add ~2kb gzipped to CSS bundle",
    "lazyLoad": "Non-critical status colors can load after interactive"
  },

