{
  "$schema": "https://tandem.design/schemas/tokens/semantic/spacing.json",
  "$description": "Semantic spacing layer - Contextual spacing referencing primitives. Defines usage, REM/PX logic, and WCAG requirements.",
  "$version": "1.0.0",
  "$hierarchy": "primitives/spacing.json → THIS FILE (context) → components/*.json (behavioral)",
  "$rule": "MUST reference {primitives.spacing.*} - NO raw pixel values allowed",

  "component": {
    "xs": {
      "value": "{primitives.spacing.1}",
      "px": "4px",
      "rem": "0.25rem",
      "usage": ["icon-padding", "badge-padding", "chip-gap"]
    },
    "sm": {
      "value": "{primitives.spacing.2}",
      "px": "8px",
      "rem": "0.5rem",
      "usage": ["button-y-padding", "input-padding", "card-internal-gap"]
    },
    "md": {
      "value": "{primitives.spacing.4}",
      "px": "16px",
      "rem": "1rem",
      "usage": ["card-padding", "section-internal-gap", "list-item-padding"],
      "default": true
    },
    "lg": {
      "value": "{primitives.spacing.6}",
      "px": "24px",
      "rem": "1.5rem",
      "usage": ["hero-padding", "feature-card-padding", "modal-padding"]
    },
    "xl": {
      "value": "{primitives.spacing.8}",
      "px": "32px",
      "rem": "2rem",
      "usage": ["landing-page-padding", "pricing-card-padding"]
    }
  },

  "stack": {
    "xs": {
      "value": "{primitives.spacing.1}",
      "px": "4px",
      "usage": ["navigation-items", "tight-lists"]
    },
    "sm": {
      "value": "{primitives.spacing.2}",
      "px": "8px",
      "usage": ["form-field-stack", "menu-items"]
    },
    "md": {
      "value": "{primitives.spacing.4}",
      "px": "16px",
      "usage": ["paragraph-spacing", "section-content-gap"],
      "default": true
    },
    "lg": {
      "value": "{primitives.spacing.6}",
      "px": "24px",
      "usage": ["subsection-gap", "card-stack-gap"]
    },
    "xl": {
      "value": "{primitives.spacing.12}",
      "px": "48px",
      "usage": ["section-gap", "major-content-blocks"]
    }
  },

  "inline": {
    "xs": {
      "value": "{primitives.spacing.1}",
      "px": "4px",
      "usage": ["icon-text-gap", "badge-gap"]
    },
    "sm": {
      "value": "{primitives.spacing.2}",
      "px": "8px",
      "usage": ["button-icon-gap", "tag-gap"],
      "default": true
    },
    "md": {
      "value": "{primitives.spacing.4}",
      "px": "16px",
      "usage": ["button-group-gap", "breadcrumb-gap"]
    },
    "lg": {
      "value": "{primitives.spacing.6}",
      "px": "24px",
      "usage": ["navigation-link-gap", "feature-column-gap"]
    }
  },

  "inset": {
    "xs": {
      "value": "{primitives.spacing.1}",
      "px": "4px",
      "usage": ["badge-padding", "pill-padding"]
    },
    "sm": {
      "value": "{primitives.spacing.2}",
      "px": "8px",
      "usage": ["button-padding-y", "input-padding-y"],
      "tapTarget": "Below 44px minimum"
    },
    "md": {
      "value": "{primitives.spacing.3}",
      "px": "12px",
      "usage": ["button-padding-x", "input-padding"],
      "tapTarget": "40px with 16px text"
    },
    "lg": {
      "value": "{primitives.spacing.4}",
      "px": "16px",
      "usage": ["card-padding", "modal-padding"],
      "tapTarget": "48px with 16px text (iOS recommended)"
    },
    "xl": {
      "value": "{primitives.spacing.6}",
      "px": "24px",
      "usage": ["hero-padding", "feature-section-padding"]
    },
    "2xl": {
      "value": "{primitives.spacing.8}",
      "px": "32px",
      "usage": ["landing-section-padding", "large-card-padding"]
    }
  },

  "layout": {
    "container": {
      "xs": {
        "value": "{primitives.spacing.4}",
        "px": "16px",
        "breakpoint": "mobile"
      },
      "sm": {
        "value": "{primitives.spacing.6}",
        "px": "24px",
        "breakpoint": "640px"
      },
      "md": {
        "value": "{primitives.spacing.8}",
        "px": "32px",
        "breakpoint": "768px"
      },
      "lg": {
        "value": "{primitives.spacing.12}",
        "px": "48px",
        "breakpoint": "1024px"
      },
      "xl": {
        "value": "{primitives.spacing.16}",
        "px": "64px",
        "breakpoint": "1280px"
      }
    },
    "section": {
      "sm": {
        "value": "{primitives.spacing.12}",
        "px": "48px",
        "usage": ["subsection-spacing", "mobile-section-gap"]
      },
      "md": {
        "value": "{primitives.spacing.16}",
        "px": "64px",
        "usage": ["section-spacing", "desktop-section-gap"],
        "default": true
      },
      "lg": {
        "value": "{primitives.spacing.24}",
        "px": "96px",
        "usage": ["major-section-gap", "landing-page-sections"]
      },
      "xl": {
        "value": "{primitives.spacing.32}",
        "px": "128px",
        "usage": ["hero-to-content", "premium-landing-sections"]
      }
    }
  },

  "grid": {
    "xs": {
      "value": "{primitives.spacing.2}",
      "px": "8px",
      "usage": ["dense-card-grid", "image-gallery"]
    },
    "sm": {
      "value": "{primitives.spacing.4}",
      "px": "16px",
      "usage": ["card-grid", "feature-grid"]
    },
    "md": {
      "value": "{primitives.spacing.6}",
      "px": "24px",
      "usage": ["default-grid", "responsive-grid"],
      "default": true
    },
    "lg": {
      "value": "{primitives.spacing.8}",
      "px": "32px",
      "usage": ["spacious-grid", "feature-sections"]
    },
    "xl": {
      "value": "{primitives.spacing.12}",
      "px": "48px",
      "usage": ["landing-page-grid", "hero-sections"]
    }
  },

  "density": {
    "compact": {
      "multiplier": 0.75,
      "description": "Information-dense layouts - dashboards, data tables, admin interfaces",
      "component": {
        "xs": "{primitives.spacing.0.5}",
        "sm": "{primitives.spacing.1.5}",
        "md": "{primitives.spacing.3}",
        "lg": "{primitives.spacing.4}",
        "xl": "{primitives.spacing.6}"
      },
      "stack": {
        "xs": "{primitives.spacing.0.5}",
        "sm": "{primitives.spacing.1.5}",
        "md": "{primitives.spacing.3}",
        "lg": "{primitives.spacing.4}",
        "xl": "{primitives.spacing.9}"
      },
      "inset": {
        "xs": "{primitives.spacing.0.5}",
        "sm": "{primitives.spacing.1.5}",
        "md": "{primitives.spacing.2}",
        "lg": "{primitives.spacing.3}",
        "xl": "{primitives.spacing.4}"
      },
      "usage": ["dashboards", "data-tables", "admin-panels", "power-user-tools"],
      "personality": "efficient, information-rich, technical"
    },
    "comfortable": {
      "multiplier": 1.0,
      "description": "Standard spacing - balanced for most use cases",
      "component": {
        "xs": "{primitives.spacing.1}",
        "sm": "{primitives.spacing.2}",
        "md": "{primitives.spacing.4}",
        "lg": "{primitives.spacing.6}",
        "xl": "{primitives.spacing.8}"
      },
      "stack": {
        "xs": "{primitives.spacing.1}",
        "sm": "{primitives.spacing.2}",
        "md": "{primitives.spacing.4}",
        "lg": "{primitives.spacing.6}",
        "xl": "{primitives.spacing.12}"
      },
      "inset": {
        "xs": "{primitives.spacing.1}",
        "sm": "{primitives.spacing.2}",
        "md": "{primitives.spacing.3}",
        "lg": "{primitives.spacing.4}",
        "xl": "{primitives.spacing.6}"
      },
      "usage": ["consumer-apps", "marketing-sites", "general-purpose"],
      "default": true,
      "personality": "balanced, familiar, accessible"
    },
    "spacious": {
      "multiplier": 1.25,
      "description": "Generous whitespace - premium, editorial, luxury brands",
      "component": {
        "xs": "{primitives.spacing.1.5}",
        "sm": "{primitives.spacing.2.5}",
        "md": "{primitives.spacing.5}",
        "lg": "{primitives.spacing.7}",
        "xl": "{primitives.spacing.10}"
      },
      "stack": {
        "xs": "{primitives.spacing.1.5}",
        "sm": "{primitives.spacing.2.5}",
        "md": "{primitives.spacing.5}",
        "lg": "{primitives.spacing.7}",
        "xl": "{primitives.spacing.14}"
      },
      "inset": {
        "xs": "{primitives.spacing.1.5}",
        "sm": "{primitives.spacing.2.5}",
        "md": "{primitives.spacing.4}",
        "lg": "{primitives.spacing.5}",
        "xl": "{primitives.spacing.8}"
      },
      "usage": ["landing-pages", "portfolios", "luxury-brands", "editorial-layouts"],
      "personality": "premium, confident, curated, high-end"
    }
  },

  "$remVsPxDecisionTree": {
    "useRem": {
      "when": "Spacing relates to typography or should scale with user font preferences",
      "examples": ["component internal padding", "text-related gaps", "line-height spacing"],
      "accessibility": "Respects user's browser font size settings (WCAG 1.4.4)"
    },
    "usePx": {
      "when": "Layout precision and consistency matter more than scaling",
      "examples": ["borders (1px)", "shadows", "grid gaps", "container padding"],
      "rationale": "Fixed values ensure pixel-perfect rendering"
    }
  },

  "$accessibilityRequirements": {
    "tapTargets": {
      "minimum": "44×44px (WCAG 2.1 Level AAA 2.5.5)",
      "comfortable": "48×48px (iOS Human Interface Guidelines)",
      "implementation": {
        "button": "text(16px) + inset.md(12px × 2) + border(2px × 2) = 44px",
        "input": "text(16px) + inset.lg(16px × 2) + border(2px × 2) = 50px"
      },
      "applies": ["buttons", "links", "inputs", "any-interactive-element"]
    },
    "textSpacing": {
      "lineHeight": "≥ 1.5× font size (WCAG 1.4.12)",
      "paragraphSpacing": "≥ 2× font size",
      "letterSpacing": "≥ 0.12× font size",
      "wordSpacing": "≥ 0.16× font size"
    }
  },

  "$responsiveStrategy": {
    "mobile": "Use sm/md values - preserve screen space",
    "tablet": "Use md/lg values - comfortable spacing",
    "desktop": "Use lg/xl values - generous spacing",
    "rule": "Component spacing uses rem (scales). Layout spacing uses px (fixed)."
  },

  "$heroComponentMapping": {
    "containerX": {
      "mobile": "{semantic.spacing.layout.container.xs}",
      "tablet": "{semantic.spacing.layout.container.sm}",
      "desktop": "{semantic.spacing.layout.container.lg}",
      "tailwind": "px-4 sm:px-6 lg:px-12 xl:px-16"
    },
    "containerY": {
      "value": "{semantic.spacing.inset.xl}",
      "tailwind": "py-8 lg:py-12"
    },
    "contentSpacing": {
      "value": "{semantic.spacing.stack.md}",
      "tailwind": "space-y-4 lg:space-y-6"
    },
    "buttonSpacing": {
      "value": "{semantic.spacing.inline.md}",
      "tailwind": "gap-4"
    }
  }
}