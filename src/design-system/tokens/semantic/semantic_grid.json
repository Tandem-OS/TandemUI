{
  "$schema": "https://tandem.design/schemas/tokens/semantic/grid.json",
  "$description": "Semantic grid - Layout patterns referencing primitives.",
  "$version": "1.0.0",
  "$hierarchy": "primitives/grid.json → THIS FILE → components/*.json",
  "$rule": "MUST reference {primitives.grid.*}",

  "layouts": {
    "singleColumn": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["mobile-default", "stacked-content"]
      },
      "tablet": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["centered-content", "blog-posts"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.12}",
        "usage": ["landing-pages", "focused-content"]
      }
    },

    "twoColumn": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.4}",
        "usage": ["stack-on-mobile"]
      },
      "tablet": {
        "columns": "{primitives.grid.templateColumns.2fr}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["tablet-side-by-side"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.2fr}",
        "gap": "{primitives.grid.gap.12}",
        "usage": ["split-hero", "feature-comparison", "pros-cons"]
      }
    },

    "threeColumn": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.4}",
        "usage": ["mobile-stack"]
      },
      "tablet": {
        "columns": "{primitives.grid.templateColumns.2fr}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["tablet-2-columns"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.3fr}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["features", "pricing-tiers", "team-cards"]
      }
    },

    "fourColumn": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.4}",
        "usage": ["mobile-stack"]
      },
      "tablet": {
        "columns": "{primitives.grid.templateColumns.2fr}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["tablet-2x2-grid"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.4fr}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["image-galleries", "product-grids", "icon-features"]
      }
    },

    "autoFit": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.4}",
        "usage": ["responsive-mobile"]
      },
      "tablet": {
        "columns": "{primitives.grid.templateColumns.autoFit250}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["fluid-tablet-layout"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.autoFit300}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["responsive-card-grid", "blog-posts", "portfolio"]
      }
    },

    "sidebar": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["stack-sidebar-below"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.sidebar}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["app-layout", "docs", "settings-page"]
      }
    },

    "sidebarReverse": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["stack-sidebar-below"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.sidebarReverse}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["right-sidebar", "ecommerce", "blog"]
      }
    },

    "dashboard": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.4}",
        "usage": ["mobile-dashboard-stack"]
      },
      "tablet": {
        "columns": "{primitives.grid.templateColumns.6fr}",
        "gap": "{primitives.grid.gap.4}",
        "usage": ["tablet-dashboard"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.12fr}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["admin-dashboard", "analytics", "data-viz"]
      }
    },

    "asymmetric60-40": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["mobile-stack"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.60-40}",
        "gap": "{primitives.grid.gap.12}",
        "usage": ["hero-emphasis-left", "content-heavy-left"]
      }
    },

    "asymmetric70-30": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["mobile-stack"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.70-30}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["main-content-with-sidebar", "blog-with-widgets"]
      }
    },

    "goldenRatio": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["mobile-stack"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.goldenRatio}",
        "gap": "{primitives.grid.gap.12}",
        "usage": ["editorial-layouts", "aesthetic-balance", "portfolio"]
      }
    },

    "masonry": {
      "mobile": {
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.4}",
        "autoFlow": "{primitives.grid.autoFlow.rowDense}",
        "usage": ["mobile-masonry"]
      },
      "tablet": {
        "columns": "{primitives.grid.templateColumns.2fr}",
        "gap": "{primitives.grid.gap.4}",
        "autoFlow": "{primitives.grid.autoFlow.rowDense}",
        "usage": ["tablet-masonry"]
      },
      "desktop": {
        "columns": "{primitives.grid.templateColumns.3fr}",
        "gap": "{primitives.grid.gap.6}",
        "autoFlow": "{primitives.grid.autoFlow.rowDense}",
        "usage": ["pinterest-style", "image-galleries", "varied-heights"]
      }
    },

    "holyGrail": {
      "mobile": {
        "rows": "{primitives.grid.templateRows.header-content-footer}",
        "columns": "{primitives.grid.templateColumns.1fr}",
        "gap": "{primitives.grid.gap.0}",
        "usage": ["classic-app-layout"]
      },
      "desktop": {
        "rows": "{primitives.grid.templateRows.header-content-footer}",
        "columns": "auto 1fr auto",
        "gap": "{primitives.grid.gap.0}",
        "usage": ["fixed-header-footer-sidebars"]
      }
    }
  },

  "componentPatterns": {
    "hero": {
      "mobile": {
        "columns": "{primitives.grid.columns.1}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["hero-stacked-mobile"]
      },
      "desktop": {
        "columns": "{primitives.grid.columns.2}",
        "gap": "{primitives.grid.gap.12}",
        "usage": ["hero-split-desktop"]
      }
    },

    "features": {
      "mobile": {
        "columns": "{primitives.grid.columns.1}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["feature-cards-stacked"]
      },
      "tablet": {
        "columns": "{primitives.grid.columns.2}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["feature-cards-2-col"]
      },
      "desktop": {
        "columns": "{primitives.grid.columns.3}",
        "gap": "{primitives.grid.gap.10}",
        "usage": ["feature-cards-3-col"]
      }
    },

    "pricing": {
      "mobile": {
        "columns": "{primitives.grid.columns.1}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["pricing-tiers-stacked"]
      },
      "tablet": {
        "columns": "{primitives.grid.columns.2}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["pricing-tiers-2-col"]
      },
      "desktop": {
        "columns": "{primitives.grid.columns.3}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["pricing-tiers-3-col"]
      }
    },

    "testimonials": {
      "mobile": {
        "columns": "{primitives.grid.columns.1}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["testimonial-stacked"]
      },
      "tablet": {
        "columns": "{primitives.grid.columns.2}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["testimonial-2-col"]
      },
      "desktop": {
        "columns": "{primitives.grid.columns.3}",
        "gap": "{primitives.grid.gap.10}",
        "usage": ["testimonial-3-col"]
      }
    },

    "gallery": {
      "mobile": {
        "columns": "{primitives.grid.columns.2}",
        "gap": "{primitives.grid.gap.2}",
        "usage": ["compact-mobile-grid"]
      },
      "tablet": {
        "columns": "{primitives.grid.columns.3}",
        "gap": "{primitives.grid.gap.4}",
        "usage": ["tablet-gallery"]
      },
      "desktop": {
        "columns": "{primitives.grid.columns.4}",
        "gap": "{primitives.grid.gap.6}",
        "usage": ["full-gallery"]
      }
    },

    "blog": {
      "mobile": {
        "columns": "{primitives.grid.columns.1}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["blog-posts-stacked"]
      },
      "tablet": {
        "columns": "{primitives.grid.columns.2}",
        "gap": "{primitives.grid.gap.8}",
        "usage": ["blog-posts-2-col"]
      },
      "desktop": {
        "columns": "{primitives.grid.columns.3}",
        "gap": "{primitives.grid.gap.10}",
        "usage": ["blog-posts-3-col"]
      }
    }
  },

  "$usageGuidelines": {
    "mobile": "Always start with 1-column layouts on mobile",
    "tablet": "Use 2-3 columns on tablet for most content",
    "desktop": "3-4 columns optimal for card-based layouts",
    "responsive": "Use autoFit patterns for truly fluid responsive grids",
    "gaps": "Smaller gaps on mobile (4-6), larger on desktop (8-12)",
    "asymmetric": "Use golden ratio or 60-40 splits for visual interest"
  }
}
