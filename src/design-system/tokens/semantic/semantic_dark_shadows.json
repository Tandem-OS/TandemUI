{
  "$schema": "https://tandem.design/schemas/tokens/semantic/dark/shadows.json",
  "$description": "Semantic shadows for dark theme - Values reference color primitives with formulas (2x opacity)",
  "$version": "2.0.0",
  "$mode": "dark",
  "$references": ["primitives/colors.json"],
  "$hierarchy": "primitives/colors.json → THIS FILE → components",
  "$rule": "ALL values use formula notation: {primitives.colors.X.Y} / opacity (2x light mode)",

  "$formula": {
    "base": "{primitives.colors.neutral.975}",
    "baseValue": "#080A12",
    "opacityRange": "0.10 - 0.40 (10% - 40%, 2x light mode)"
  },

  "elevation": {
    "none": "none",
    "xs": "0 1px 2px 0 {primitives.colors.neutral.975}/0.10",
    "sm": "0 1px 3px 0 {primitives.colors.neutral.975}/0.16, 0 1px 2px -1px {primitives.colors.neutral.975}/0.16",
    "md": "0 4px 6px -1px {primitives.colors.neutral.975}/0.20, 0 2px 4px -2px {primitives.colors.neutral.975}/0.20",
    "lg": "0 10px 15px -3px {primitives.colors.neutral.975}/0.24, 0 4px 6px -4px {primitives.colors.neutral.975}/0.24",
    "xl": "0 20px 25px -5px {primitives.colors.neutral.975}/0.32, 0 8px 10px -6px {primitives.colors.neutral.975}/0.32",
    "2xl": "0 25px 50px -12px {primitives.colors.neutral.975}/0.40"
  },

  "card": {
    "default": "{this.elevation.sm}",
    "hover": "{this.elevation.md}",
    "active": "{this.elevation.xs}",
    "selected": "{this.elevation.md}",
    "disabled": "none"
  },

  "button": {
    "default": "none",
    "hover": "{this.elevation.sm}",
    "active": "none",
    "disabled": "none"
  },

  "input": {
    "default": "none",
    "hover": "none",
    "focus": "{this.focus.default}",
    "error": "{this.focus.error}",
    "disabled": "none"
  },

  "dropdown": {
    "default": "{this.elevation.lg}",
    "hover": "{this.elevation.xl}"
  },

  "modal": {
    "backdrop": "none",
    "content": "{this.elevation.2xl}"
  },

  "popover": {
    "default": "{this.elevation.lg}"
  },

  "tooltip": {
    "default": "{this.elevation.md}"
  },

  "navigation": {
    "sticky": "{this.elevation.md}",
    "fixed": "{this.elevation.lg}",
    "floating": "{this.elevation.xl}"
  },

  "focus": {
    "default": "0 0 0 3px {primitives.colors.indigo.400}/0.32",
    "error": "0 0 0 3px {primitives.colors.red.400}/0.32",
    "success": "0 0 0 3px {primitives.colors.green.400}/0.32",
    "warning": "0 0 0 3px {primitives.colors.amber.400}/0.32",
    "info": "0 0 0 3px {primitives.colors.blue.400}/0.32"
  },

  "glow": {
    "primary": "0 0 32px 0 {primitives.colors.indigo.400}/0.48",
    "secondary": "0 0 32px 0 {primitives.colors.orange.400}/0.48",
    "tertiary": "0 0 32px 0 {primitives.colors.emerald.400}/0.48",
    "success": "0 0 32px 0 {primitives.colors.green.400}/0.48",
    "error": "0 0 32px 0 {primitives.colors.red.400}/0.48",
    "warning": "0 0 32px 0 {primitives.colors.amber.400}/0.48",
    "info": "0 0 32px 0 {primitives.colors.blue.400}/0.48"
  },

  "colored": {
    "primary": {
      "sm": "0 1px 3px 0 {primitives.colors.indigo.400}/0.24",
      "md": "0 4px 6px -1px {primitives.colors.indigo.400}/0.24",
      "lg": "0 10px 15px -3px {primitives.colors.indigo.400}/0.24"
    },
    "secondary": {
      "sm": "0 1px 3px 0 {primitives.colors.orange.400}/0.24",
      "md": "0 4px 6px -1px {primitives.colors.orange.400}/0.24",
      "lg": "0 10px 15px -3px {primitives.colors.orange.400}/0.24"
    },
    "tertiary": {
      "sm": "0 1px 3px 0 {primitives.colors.emerald.400}/0.24",
      "md": "0 4px 6px -1px {primitives.colors.emerald.400}/0.24",
      "lg": "0 10px 15px -3px {primitives.colors.emerald.400}/0.24"
    },
    "success": {
      "sm": "0 1px 3px 0 {primitives.colors.green.400}/0.24",
      "md": "0 4px 6px -1px {primitives.colors.green.400}/0.24",
      "lg": "0 10px 15px -3px {primitives.colors.green.400}/0.24"
    },
    "error": {
      "sm": "0 1px 3px 0 {primitives.colors.red.400}/0.24",
      "md": "0 4px 6px -1px {primitives.colors.red.400}/0.24",
      "lg": "0 10px 15px -3px {primitives.colors.red.400}/0.24"
    },
    "warning": {
      "sm": "0 1px 3px 0 {primitives.colors.amber.400}/0.24",
      "md": "0 4px 6px -1px {primitives.colors.amber.400}/0.24",
      "lg": "0 10px 15px -3px {primitives.colors.amber.400}/0.24"
    }
  },

  "inner": {
    "default": "inset 0 2px 4px 0 {primitives.colors.neutral.975}/0.10",
    "subtle": "inset 0 1px 2px 0 {primitives.colors.neutral.975}/0.06"
  }
}
