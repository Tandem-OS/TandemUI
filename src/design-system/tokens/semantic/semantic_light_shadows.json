{
  "$schema": "https://tandem.design/schemas/tokens/semantic/light/shadows.json",
  "$description": "Semantic shadows for light theme - Values reference color primitives with formulas",
  "$version": "2.0.0",
  "$mode": "light",
  "$references": ["primitives/colors.json"],
  "$hierarchy": "primitives/colors.json → THIS FILE → components",
  "$rule": "ALL values use formula notation: {primitives.colors.X.Y} / opacity",

  "$formula": {
    "base": "{primitives.colors.neutral.900}",
    "baseValue": "#1A1D2E",
    "opacityRange": "0.05 - 0.20 (5% - 20%)"
  },

  "elevation": {
    "none": "none",
    "xs": "0 1px 2px 0 {primitives.colors.neutral.900}/0.05",
    "sm": "0 1px 3px 0 {primitives.colors.neutral.900}/0.08, 0 1px 2px -1px {primitives.colors.neutral.900}/0.08",
    "md": "0 4px 6px -1px {primitives.colors.neutral.900}/0.10, 0 2px 4px -2px {primitives.colors.neutral.900}/0.10",
    "lg": "0 10px 15px -3px {primitives.colors.neutral.900}/0.12, 0 4px 6px -4px {primitives.colors.neutral.900}/0.12",
    "xl": "0 20px 25px -5px {primitives.colors.neutral.900}/0.16, 0 8px 10px -6px {primitives.colors.neutral.900}/0.16",
    "2xl": "0 25px 50px -12px {primitives.colors.neutral.900}/0.20"
  },

  "card": {
    "default": "{this.elevation.sm}",
    "hover": "{this.elevation.md}",
    "active": "{this.elevation.xs}",
    "selected": "{this.elevation.md}",
    "disabled": "none"
  },

  "button": {
    "default": "none",
    "hover": "{this.elevation.sm}",
    "active": "none",
    "disabled": "none"
  },

  "input": {
    "default": "none",
    "hover": "none",
    "focus": "{this.focus.default}",
    "error": "{this.focus.error}",
    "disabled": "none"
  },

  "dropdown": {
    "default": "{this.elevation.lg}",
    "hover": "{this.elevation.xl}"
  },

  "modal": {
    "backdrop": "none",
    "content": "{this.elevation.2xl}"
  },

  "popover": {
    "default": "{this.elevation.lg}"
  },

  "tooltip": {
    "default": "{this.elevation.md}"
  },

  "navigation": {
    "sticky": "{this.elevation.md}",
    "fixed": "{this.elevation.lg}",
    "floating": "{this.elevation.xl}"
  },

  "focus": {
    "default": "0 0 0 3px {primitives.colors.indigo.500}/0.24",
    "error": "0 0 0 3px {primitives.colors.red.500}/0.24",
    "success": "0 0 0 3px {primitives.colors.green.500}/0.24",
    "warning": "0 0 0 3px {primitives.colors.amber.500}/0.24",
    "info": "0 0 0 3px {primitives.colors.blue.500}/0.24"
  },

  "glow": {
    "primary": "0 0 24px 0 {primitives.colors.indigo.500}/0.32",
    "secondary": "0 0 24px 0 {primitives.colors.orange.500}/0.32",
    "tertiary": "0 0 24px 0 {primitives.colors.emerald.500}/0.32",
    "success": "0 0 24px 0 {primitives.colors.green.500}/0.32",
    "error": "0 0 24px 0 {primitives.colors.red.500}/0.32",
    "warning": "0 0 24px 0 {primitives.colors.amber.500}/0.32",
    "info": "0 0 24px 0 {primitives.colors.blue.500}/0.32"
  },

  "colored": {
    "primary": {
      "sm": "0 1px 3px 0 {primitives.colors.indigo.500}/0.16",
      "md": "0 4px 6px -1px {primitives.colors.indigo.500}/0.16",
      "lg": "0 10px 15px -3px {primitives.colors.indigo.500}/0.16"
    },
    "secondary": {
      "sm": "0 1px 3px 0 {primitives.colors.orange.500}/0.16",
      "md": "0 4px 6px -1px {primitives.colors.orange.500}/0.16",
      "lg": "0 10px 15px -3px {primitives.colors.orange.500}/0.16"
    },
    "tertiary": {
      "sm": "0 1px 3px 0 {primitives.colors.emerald.500}/0.16",
      "md": "0 4px 6px -1px {primitives.colors.emerald.500}/0.16",
      "lg": "0 10px 15px -3px {primitives.colors.emerald.500}/0.16"
    },
    "success": {
      "sm": "0 1px 3px 0 {primitives.colors.green.500}/0.16",
      "md": "0 4px 6px -1px {primitives.colors.green.500}/0.16",
      "lg": "0 10px 15px -3px {primitives.colors.green.500}/0.16"
    },
    "error": {
      "sm": "0 1px 3px 0 {primitives.colors.red.500}/0.16",
      "md": "0 4px 6px -1px {primitives.colors.red.500}/0.16",
      "lg": "0 10px 15px -3px {primitives.colors.red.500}/0.16"
    },
    "warning": {
      "sm": "0 1px 3px 0 {primitives.colors.amber.500}/0.16",
      "md": "0 4px 6px -1px {primitives.colors.amber.500}/0.16",
      "lg": "0 10px 15px -3px {primitives.colors.amber.500}/0.16"
    }
  },

  "inner": {
    "default": "inset 0 2px 4px 0 {primitives.colors.neutral.900}/0.05",
    "subtle": "inset 0 1px 2px 0 {primitives.colors.neutral.900}/0.03"
  }
}
