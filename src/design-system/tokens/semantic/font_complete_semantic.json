{
  "$schema": "https://tandem.design/schemas/tokens/semantic/typography.json",
  "$description": "Semantic typography - Complete text components with 16 personality profiles. Matches Hero_01 pattern (text-h1-md, text-h2-sm, etc.)",
  "$version": "2.0.0",
  "$hierarchy": "primitives/fontSize|fontWeight|etc → THIS FILE → components/*.json",
