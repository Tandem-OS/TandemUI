        "tailwind": "text-3xl font-bold tracking-tighter leading-tight",
        "usage": ["h1-mobile", "small-screens"]
      },
      "md": {
        "fontSize": "{primitives.fontSize.4xl}",
        "lineHeight": "{primitives.lineHeight.tight}",
        "fontWeight": "{primitives.fontWeight.700}",
        "letterSpacing": "{primitives.letterSpacing.tighter}",
        "fontFamily": "{primitives.fontFamilies.display}",
        "tailwind": "text-4xl font-bold tracking-tighter leading-tight",
