  "$personalityDecisionFramework": {
    "step1": "Identify your primary audience (technical, business, consumer, wellness, creative, luxury)",
    "step2": "Map 3-5 brand voice adjectives (see $personalityMapping)",
    "step3": "Consider industry norms and price point",
    "step4": "Prototype 2-3 candidate personalities",
    "step5": "User test with 5+ target users",
    "step6": "A/B test finalists (2 weeks, 1000+ conversions)",
    "step7": "Document choice and rationale"
  },

  "$hero01Mapping": {
    "heading": {
      "mobile": "{semantic.typography.heading.h2.sm}",
      "desktop": "{semantic.typography.heading.h1.md}",
      "responsive": "text-2xl lg:text-4xl font-bold tracking-tighter leading-tight break-words"
    },
    "body": {
      "mobile": "{semantic.typography.body.md}",
      "desktop": "{semantic.typography.body.lg}",
      "responsive": "text-base lg:text-lg font-normal leading-relaxed break-words"
    },
    "button": "{semantic.typography.button.lg}",
    "overline": "{semantic.typography.overline.md}"
  },

  "$accessibilityRequirements": {
    "textSpacing": {
      "lineHeight": "≥ 1.5× font size (WCAG 1.4.12)",
      "paragraphSpacing": "≥ 2× font size",
      "letterSpacing": "≥ 0.12× font size",
      "wordSpacing": "≥ 0.16× font size"
    },
    "contrast": {
      "smallText": "4.5:1 minimum (AA) for text under 18px",
      "largeText": "3:1 minimum (AA) for 18px+ or 14px bold+",
      "AAA": "7:1 for enhanced accessibility"
    },
    "fontSizeMinimum": {
      "bodyText": "16px minimum for comfortable reading",
      "smallText": "12px absolute minimum (use sparingly)"
    },
    "linkAccessibility": {
      "underlineDefault": "Underline by default or provide 3:1 contrast difference",
      "hoverState": "Clear visual change on hover/focus",
      "focusVisible": "2px outline with 3:1 contrast for keyboard navigation"
    }
  },

  "$responsiveTypography": {
    "mobile": "Use smaller sizes (sm/md) - preserve readability on small screens",
    "tablet": "Use medium sizes (md/lg) - comfortable reading",
    "desktop": "Use larger sizes (lg/xl) - take advantage of screen space",
    "fluidScaling": "Consider clamp() for smooth scaling between breakpoints"
  },

  "$semanticMarkup": {
    "headings": "Always use proper heading hierarchy (h1→h2→h3, never skip levels)",
    "emphasis": "Use <strong> for semantic importance, not just bold styling",
    "links": "Must be understandable out of context (avoid 'click here')",
    "lists": "Use <ul>/<ol> for lists, never just styled <div> elements",
    "quotes": "Use <blockquote> for quotes with <cite> for attribution"
  },

  "$usageGuidelines": {
    "heading": "Use for page/section titles and content hierarchy",
    "body": "Primary text content - paragraphs, descriptions, explanations",
    "label": "Form labels, tags, badges, metadata, small identifiers",
    "link": "Clickable text navigation - inline links, CTAs, navigation items",
    "overline": "Eyebrows/kickers above headings for context or category",
    "quote": "Testimonials, pull quotes, blockquotes with attribution",
    "button": "Text inside interactive buttons and CTAs"
  }
}