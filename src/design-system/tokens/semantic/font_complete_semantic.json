  "$brandPersonalities": {
    "brutalist": {
      "name": "Brutalist / Computational",
      "description": "Direct, technical, no-nonsense, factual, unfiltered",
      "voice": ["technical", "precise", "uncompromising"],
      "tone": ["serious", "authoritative", "expert", "stark"],
      "psychologicalEffect": "Control, precision, technical mastery",
